<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_selected_bg" />
            <stroke android:width="2dp" android:color="@color/card_selected_border" />
            <corners android:radius="@dimen/card_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_unselected_bg" />
            <stroke android:width="1dp" android:color="@color/card_unselected_border" />
            <corners android:radius="@dimen/card_corner_radius" />
        </shape>
    </item>
</selector>

