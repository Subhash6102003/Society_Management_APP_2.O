<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@drawable/ic_profile"
            android:contentDescription="Back"
            android:layout_marginBottom="@dimen/spacing_md" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_up_title"
            android:textSize="@dimen/text_headline"
            android:textColor="?colorOnBackground"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_your_role"
            android:textSize="@dimen/text_body"
            android:textColor="?colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xl" />

        <!-- Resident Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResident"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_resident"
                    android:textSize="@dimen/text_title"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_resident_desc"
                    android:textSize="@dimen/text_label"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_xs" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tenant Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTenant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_tenant"
                    android:textSize="@dimen/text_title"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_tenant_desc"
                    android:textSize="@dimen/text_label"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_xs" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Security Guard Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSecurityGuard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_security_guard"
                    android:textSize="@dimen/text_title"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_security_guard_desc"
                    android:textSize="@dimen/text_label"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_xs" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Worker / Maintenance Staff Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWorker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_worker"
                    android:textSize="@dimen/text_title"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_worker_desc"
                    android:textSize="@dimen/text_label"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_xs" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Continue button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            style="@style/Widget.MGBHeights.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_continue"
            android:enabled="false" />

    </LinearLayout>

</ScrollView>

