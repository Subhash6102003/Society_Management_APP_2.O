<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:colorBackground"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivGuardPhoto"
                    android:layout_width="@dimen/avatar_md"
                    android:layout_height="@dimen/avatar_md"
                    android:src="@drawable/ic_profile"
                    android:background="@drawable/bg_icon_circle"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvGuardName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_dashboard"
                        android:textSize="@dimen/text_title"
                        android:textColor="?colorOnBackground"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvShiftInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Off Duty"
                        android:textSize="@dimen/text_label"
                        android:textColor="?colorOnSurfaceVariant" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmergencyAlert"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@drawable/ic_notification"
                    app:iconTint="@color/error"
                    android:contentDescription="Emergency" />
            </LinearLayout>

            <!-- Shift Toggle Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shift_status"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="?colorOnSurface"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvShiftStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toggle to start your shift"
                            android:textSize="@dimen/text_label"
                            android:textColor="?colorOnSurfaceVariant" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchShift"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Register Visitor Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegisterVisitor"
                style="@style/Widget.MGBHeights.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/register_visitor"
                android:layout_marginBottom="@dimen/spacing_md"
                app:icon="@drawable/ic_visitors"
                app:iconGravity="start" />

            <!-- Active Visitors Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/active_visitors"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnBackground"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActiveCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    app:chipBackgroundColor="@color/primary_container" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActiveVisitors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Empty state for active visitors -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNoActiveVisitors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/spacing_lg"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No active visitors"
                        android:textSize="@dimen/text_body"
                        android:textColor="?colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Entry Log -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/entry_exit_log"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnBackground"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewAllLogs"
                    style="@style/Widget.MGBHeights.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEntryLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

