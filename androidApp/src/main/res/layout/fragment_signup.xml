<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?selectableItemBackgroundBorderless"
            android:src="@drawable/ic_profile"
            android:contentDescription="Back"
            android:layout_marginBottom="@dimen/spacing_md" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account"
            android:textSize="@dimen/text_headline"
            android:textColor="?colorOnBackground"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Role badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/primary_container"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_xs"
                android:textSize="@dimen/text_label"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-medium" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Personal Details -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Details"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:hint="@string/hint_full_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:hint="@string/hint_phone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLength="10" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:hint="@string/hint_email_address">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_password"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- House Details (hidden for Worker/Security roles) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHouseDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="House Details"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:hint="@string/hint_flat_number">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFlatNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_tower_block">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTowerBlock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Profile Photo -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfilePhoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Photo"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <ImageView
                        android:id="@+id/ivProfilePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_icon_circle"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile"
                        android:padding="20dp" />

                </FrameLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureProfile"
                    style="@style/Widget.MGBHeights.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Add Profile Photo"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ID Proof (for Tenant, Security Guard, Worker only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIdProof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID Proof (Aadhaar / Licence)"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <ImageView
                    android:id="@+id/ivIdProof"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_notices"
                    android:background="@color/icon_circle_bg"
                    android:padding="24dp"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureIdProof"
                    style="@style/Widget.MGBHeights.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Add ID Proof"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Error message -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error"
            android:textSize="@dimen/text_label"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Register button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            style="@style/Widget.MGBHeights.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/btn_register"
            android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Loading -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminate="true"
            app:indicatorColor="@color/primary" />

        <!-- Already have account -->
        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/already_have_account_login"
            android:textSize="@dimen/text_body"
            android:textColor="@color/primary"
            android:gravity="center"
            android:padding="@dimen/spacing_sm"
            android:background="?selectableItemBackground" />

    </LinearLayout>

</ScrollView>

