<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_xl">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize"
            app:navigationIcon="?homeAsUpIndicator"
            app:title="User Details" />

        <!-- Header: Profile Photo & Basic Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_lg">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:background="@drawable/bg_icon_circle"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textSize="@dimen/text_headline"
                android:textColor="?colorOnBackground"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/primary_container"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/primary" />

        </LinearLayout>

        <!-- Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <include android:id="@+id/rowEmail" layout="@layout/item_detail_row" />
                <include android:id="@+id/rowPhone" layout="@layout/item_detail_row" />
                <include android:id="@+id/rowFlat" layout="@layout/item_detail_row" />
                <include android:id="@+id/rowTower" layout="@layout/item_detail_row" />
                <include android:id="@+id/rowJoined" layout="@layout/item_detail_row" />
                <include android:id="@+id/rowStatus" layout="@layout/item_detail_row" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ID Proof Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="Documents"
            android:textSize="@dimen/text_subtitle"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIdProof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID Proof"
                    android:textSize="@dimen/text_label"
                    android:textColor="?colorOnSurfaceVariant" />

                <ImageView
                    android:id="@+id/ivIdProof"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_notices"
                    android:background="@color/icon_circle_bg"
                    android:padding="24dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <LinearLayout
            android:id="@+id/layoutAdminActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_md"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                style="@style/Widget.MGBHeights.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="Approve"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MGBHeights.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:text="Delete User"
                android:textColor="@color/error"
                app:strokeColor="@color/error" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
