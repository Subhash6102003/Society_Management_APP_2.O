<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_margin="-24dp"
        android:layout_marginBottom="24dp"
        app:title="Book a Worker"
        app:navigationIcon="@drawable/ic_profile" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <ImageView
            android:id="@+id/ivWorkerPhoto"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="Worker photo"
            android:src="@drawable/ic_profile" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvWorkerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Worker"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWorkerJobType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Job Type" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWorkerRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs 0/hr"
            android:textStyle="bold" />
    </LinearLayout>

        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

</LinearLayout>
