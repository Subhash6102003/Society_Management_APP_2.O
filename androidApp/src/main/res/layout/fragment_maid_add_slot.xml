<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <EditText android:id="@+id/etFlatNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Flat Number" />
        <EditText android:id="@+id/etBuildingNumber" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Building Number" />
        <EditText android:id="@+id/etWorkDays" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Work Days (Mon,Tue,...)" />
        <EditText android:id="@+id/etWorkTimings" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Work Timings (09:00-11:00)" />
        <EditText android:id="@+id/etWorkType" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Work Type" />
        <Button
            android:id="@+id/btnConfirmSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Confirm" />
    </LinearLayout>
</ScrollView>
