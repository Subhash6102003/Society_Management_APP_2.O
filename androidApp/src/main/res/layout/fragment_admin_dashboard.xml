<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:colorBackground"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header with gradient background -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_admin_header"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/avatar_md"
                        android:layout_height="@dimen/avatar_md"
                        android:src="@drawable/ic_profile"
                        android:background="@drawable/bg_icon_circle"
                        android:contentDescription="Admin" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/tvAdminName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_dashboard"
                            android:textSize="@dimen/text_title"
                            android:textColor="@color/on_primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/society_overview"
                            android:textSize="@dimen/text_label"
                            android:textColor="@color/on_primary"
                            android:alpha="0.8" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnNotifications"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/on_primary"
                        android:contentDescription="Notifications" />
                </LinearLayout>

                <!-- Stats Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="?colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Users"
                                android:textSize="@dimen/text_caption"
                                android:textColor="?colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/tvTotalUsers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textColor="@color/primary"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPendingApprovals"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_xs"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/status_warning">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending Approvals"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/on_primary" />

                            <TextView
                                android:id="@+id/tvPendingApprovals"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="28sp"
                                android:textColor="@color/on_primary"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Stats Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/status_success">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Collected"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/on_primary" />

                            <TextView
                                android:id="@+id/tvTotalCollected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="18sp"
                                android:textColor="@color/on_primary"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_xs"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/status_overdue">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending Amount"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/on_primary" />

                            <TextView
                                android:id="@+id/tvTotalPending"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textSize="18sp"
                                android:textColor="@color/on_primary"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>

            <!-- Content below header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Management Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Management"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnBackground"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginTop="@dimen/spacing_xs" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAdminActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

                <!-- Pending Approvals Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/pending_approvals"
                                android:textSize="@dimen/text_subtitle"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="sans-serif-bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewAllApprovals"
                                style="@style/Widget.MGBHeights.Button.Text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View All"
                                android:textSize="@dimen/text_label" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvPendingApprovals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                        <!-- Empty state for approvals -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardNoApprovals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/card_selected_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/spacing_lg">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✅ No pending approvals"
                                    android:textSize="@dimen/text_body"
                                    android:textColor="@color/status_success" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Billing Management Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/billing_management"
                            android:textSize="@dimen/text_subtitle"
                            android:textColor="?colorOnSurface"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginBottom="@dimen/spacing_md" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGenerateBills"
                                style="@style/Widget.MGBHeights.Button.Primary"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/button_height"
                                android:layout_weight="1"
                                android:layout_marginEnd="@dimen/spacing_xs"
                                android:text="@string/generate_bills"
                                android:textSize="@dimen/text_label" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnApplyLateFees"
                                style="@style/Widget.MGBHeights.Button.Outlined"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/button_height"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="Apply Late Fees"
                                android:textSize="@dimen/text_label" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Emergency Broadcast -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmergencyBroadcast"
                    style="@style/Widget.MGBHeights.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:text="🚨 Emergency Broadcast"
                    android:backgroundTint="@color/error"
                    android:layout_marginBottom="@dimen/spacing_lg" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

