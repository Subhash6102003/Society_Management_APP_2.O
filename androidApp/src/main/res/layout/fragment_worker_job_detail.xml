<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize"
            app:title="Job Details"
            app:navigationIcon="@drawable/ic_profile" />

        <!-- Status Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="In Progress"
            android:layout_marginBottom="@dimen/spacing_md"
            app:chipBackgroundColor="@color/status_info" />

        <!-- Job Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_title"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvJobDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_sm" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/divider"
                    android:layout_marginVertical="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Flat"
                            android:textSize="@dimen/text_caption"
                            android:textColor="?colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvFlatInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_body"
                            android:textColor="?colorOnSurface"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resident"
                            android:textSize="@dimen/text_caption"
                            android:textColor="?colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvResidentName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_body"
                            android:textColor="?colorOnSurface"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Amount"
                            android:textSize="@dimen/text_caption"
                            android:textColor="?colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Before / After Photos Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photos"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Before Photo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="@dimen/spacing_xs">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Before"
                            android:textSize="@dimen/text_label"
                            android:textColor="?colorOnSurfaceVariant"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardBeforePhoto"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/surface_variant_light">

                            <ImageView
                                android:id="@+id/ivBeforePhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="Before photo" />

                            <ImageView
                                android:id="@+id/ivBeforePlaceholder"
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                android:alpha="0.3"
                                android:contentDescription="Add before photo" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- After Photo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="@dimen/spacing_xs">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="After"
                            android:textSize="@dimen/text_label"
                            android:textColor="?colorOnSurfaceVariant"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAfterPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            app:cardCornerRadius="12dp"
                            app:cardBackgroundColor="@color/surface_variant_light">

                            <ImageView
                                android:id="@+id/ivAfterPhoto"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="After photo" />

                            <ImageView
                                android:id="@+id/ivAfterPlaceholder"
                                android:layout_width="@dimen/icon_lg"
                                android:layout_height="@dimen/icon_lg"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile"
                                android:alpha="0.3"
                                android:contentDescription="Add after photo" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Time Tracking Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time Spent"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Started"
                            android:textSize="@dimen/text_caption"
                            android:textColor="?colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvStartTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="@dimen/text_body"
                            android:textColor="?colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textSize="@dimen/text_caption"
                            android:textColor="?colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0h 0m"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notes Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notes"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Add work notes...">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Materials Used Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Materials Used"
                    android:textSize="@dimen/text_subtitle"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MGBHeights.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="List materials used...">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaterials"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartWork"
            style="@style/Widget.MGBHeights.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Start Work"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteWork"
            style="@style/Widget.MGBHeights.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="Mark as Complete"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRejectWork"
            style="@style/Widget.MGBHeights.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reject Job"
            android:textColor="@color/error"
            app:strokeColor="@color/error" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

