        android:id="@+id/adminUserManagementFragment"
        android:name="com.mgbheights.android.ui.admin.AdminUserManagementFragment">
        <action android:id="@+id/action_admin_user_management_to_user_detail" app:destination="@id/adminUserDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminUserDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminUserDetailFragment" />

    <fragment
        android:id="@+id/adminComplaintsFragment"
        android:name="com.mgbheights.android.ui.admin.AdminComplaintsFragment">
        <action android:id="@+id/action_admin_complaints_to_detail" app:destination="@id/adminComplaintDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminComplaintDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminComplaintDetailFragment" />

