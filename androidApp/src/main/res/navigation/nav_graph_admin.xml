<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_admin"
    app:startDestination="@id/adminDashboardFragment">

    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.mgbheights.android.ui.admin.AdminDashboardFragment">
        <action android:id="@+id/action_admin_dashboard_to_residents" app:destination="@id/adminResidentsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_tenants" app:destination="@id/adminTenantsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_guards" app:destination="@id/adminGuardsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_workers" app:destination="@id/adminWorkersFragment" />
        <action android:id="@+id/action_admin_dashboard_to_maids" app:destination="@id/adminMaidsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_user_management" app:destination="@id/adminUserManagementFragment" />
        <action android:id="@+id/action_admin_dashboard_to_complaints" app:destination="@id/adminComplaintsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_notices" app:destination="@id/adminNoticesFragment" />
        <action android:id="@+id/action_admin_dashboard_to_bills" app:destination="@id/adminBillsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_visitors_log" app:destination="@id/adminVisitorsLogFragment" />
        <action android:id="@+id/action_admin_dashboard_to_visitors" app:destination="@id/adminVisitorsFragment" />
        <action android:id="@+id/action_admin_dashboard_to_media" app:destination="@id/adminMediaFragment" />
        <action android:id="@+id/action_admin_dashboard_to_shop" app:destination="@id/adminShopFragment" />
        <action android:id="@+id/action_admin_dashboard_to_profile" app:destination="@id/adminProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminResidentsFragment"
        android:name="com.mgbheights.android.ui.admin.AdminResidentsFragment">
        <action android:id="@+id/action_admin_residents_to_detail" app:destination="@id/adminResidentDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminResidentDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminResidentDetailFragment">
        <action android:id="@+id/action_admin_resident_detail_to_user_detail" app:destination="@id/adminUserDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminTenantsFragment"
        android:name="com.mgbheights.android.ui.admin.AdminTenantsFragment">
        <action android:id="@+id/action_admin_tenants_to_detail" app:destination="@id/adminTenantDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminTenantDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminTenantDetailFragment">
        <action android:id="@+id/action_admin_tenant_detail_to_user_detail" app:destination="@id/adminUserDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminGuardsFragment"
        android:name="com.mgbheights.android.ui.admin.AdminGuardsFragment">
        <action android:id="@+id/action_admin_guards_to_detail" app:destination="@id/adminGuardDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminGuardDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminGuardDetailFragment">
        <action android:id="@+id/action_admin_guard_detail_to_user_detail" app:destination="@id/adminUserDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminWorkersFragment"
        android:name="com.mgbheights.android.ui.admin.AdminWorkersFragment">
