    </fragment>

    <fragment
        android:id="@+id/adminWorkerDetailFragment"
        android:name="com.mgbheights.android.ui.admin.AdminWorkerDetailFragment">
        <action android:id="@+id/action_admin_worker_detail_to_user_detail" app:destination="@id/adminUserDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminMaidsFragment"
        android:name="com.mgbheights.android.ui.admin.AdminMaidsFragment">
        <action android:id="@+id/action_admin_maids_to_user_detail" app:destination="@id/adminUserDetailFragment" />
