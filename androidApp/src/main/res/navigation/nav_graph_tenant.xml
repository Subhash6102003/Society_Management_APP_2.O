<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_tenant"
    app:startDestination="@id/tenantHomeFragment">

    <fragment
        android:id="@+id/tenantHomeFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantHomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_tenant_home">
        <action
            android:id="@+id/action_tenantHome_to_tenantRaiseComplaint"
            app:destination="@id/tenantRaiseComplaintFragment" />
    </fragment>

    <fragment
        android:id="@+id/tenantComplaintsFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantComplaintsFragment"
        android:label="Complaints"
        tools:layout="@layout/fragment_tenant_complaints">
        <action
            android:id="@+id/action_tenantComplaints_to_tenantRaiseComplaint"
            app:destination="@id/tenantRaiseComplaintFragment" />
    </fragment>

    <fragment
        android:id="@+id/tenantRaiseComplaintFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantRaiseComplaintFragment"
        android:label="Raise Complaint"
        tools:layout="@layout/fragment_tenant_raise_complaint" />

    <fragment
        android:id="@+id/tenantBillsFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantBillsFragment"
        android:label="Bills"
        tools:layout="@layout/fragment_tenant_bills" />

    <fragment
        android:id="@+id/tenantNoticesFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantNoticesFragment"
        android:label="Notices"
        tools:layout="@layout/fragment_tenant_notices" />

    <fragment
        android:id="@+id/tenantProfileFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_tenant_profile" />

    <fragment
        android:id="@+id/tenantSettingsFragment"
        android:name="com.mgbheights.android.ui.tenant.TenantSettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_tenant_settings" />

</navigation>
