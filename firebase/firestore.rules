rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper Functions
    // ========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && uid() == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    // Check if the authenticated user's email is the designated admin email
    function isAdminByEmail() {
      return isAuthenticated()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'admin@mgbheights.com';
    }

    function isAdmin() {
      return isAuthenticated() && (
        isAdminByEmail()
        || getUserRole() == 'ADMIN'
      );
    }

    function isResident() {
      return isAuthenticated() && getUserRole() == 'RESIDENT';
    }

    function isTenant() {
      return isAuthenticated() && getUserRole() == 'TENANT';
    }

    function isGuard() {
      return isAuthenticated() && (getUserRole() == 'SECURITY_GUARD' || getUserRole() == 'SECURITY_GUARD_WORKER');
    }

    function isWorker() {
      return isAuthenticated() && (getUserRole() == 'WORKER' || getUserRole() == 'SECURITY_GUARD_WORKER');
    }

    // Admin is ALWAYS considered approved (they are the approver)
    function isApproved() {
      return isAuthenticated()
        && (
          isAdminByEmail()
          || (getUserData().isBlocked != true
              && (getUserData().isApproved == true || getUserRole() == 'ADMIN'))
        );
    }

    function isNotBlocked() {
      return isAuthenticated() && getUserData().isBlocked != true;
    }

    // Valid user = authenticated + approved (or admin) + not blocked
    function isValidUser() {
      return isApproved();
    }

    // ========================================
    // Users Collection
    // ========================================
    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own profile on first sign-up
      allow create: if isOwner(userId);

      // Update rules:
      //  - Admin can update any user document
      //  - Owner can update own document WITH restrictions:
      //    • During initial profile setup (isProfileComplete == false):
      //      allow setting role & isApproved (but never isBlocked)
      //    • After profile is complete:
      //      block changes to role, isApproved, isBlocked
      allow update: if isAdmin()
        || isAdminByEmail()
        || (isOwner(userId) && (
            // Initial profile completion — allow role + isApproved, block isBlocked
            (resource.data.isProfileComplete == false
             && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBlocked']))
            ||
            // Normal updates — block all protected fields
            (resource.data.isProfileComplete == true
             && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'isBlocked']))
        ));

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ========================================
    // Flats Collection
    // ========================================
    match /flats/{flatId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // Maintenance Bills Collection
    // ========================================
    match /maintenance_bills/{billId} {
      allow read: if isValidUser();
      // Admin can create or update any bill
      allow create, update: if isAdmin();
      // Residents and tenants can update ONLY the payment fields on their OWN bill
      allow update: if isValidUser()
        && resource.data.residentId == uid()
        && request.resource.data.diff(resource.data)
              .affectedKeys()
              .hasOnly(['status', 'paymentId', 'paidAt', 'updatedAt']);
      allow delete: if false;
    }

    // ========================================
    // Payments Collection
    // ========================================
    match /payments/{paymentId} {
      allow read: if isValidUser();
      allow create: if isValidUser();
      allow update: if isAdmin() || (isValidUser() && resource.data.userId == uid());
      allow delete: if false;
    }

    // ========================================
    // Notices Collection
    // ========================================
    match /notices/{noticeId} {
      allow read: if isValidUser();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isValidUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if isAdmin();
    }

    // ========================================
    // Complaints Collection
    // ========================================
    match /complaints/{complaintId} {
      allow read: if isValidUser();
      allow create: if isValidUser() && (isResident() || isTenant());
      allow update: if isAdmin() ||
        (isValidUser() && resource.data.userId == uid());
      allow delete: if isAdmin();
    }

    // ========================================
    // Visitors Collection
    // ========================================
    match /visitors/{visitorId} {
      allow read: if isValidUser();
      allow create: if isValidUser() && (isGuard() || isResident() || isAdmin());
      allow update: if isValidUser() && (isGuard() || isResident() || isAdmin());
      allow delete: if isAdmin();
    }

    // ========================================
    // Workers Collection
    // ========================================
    match /workers/{workerId} {
      allow read: if isValidUser();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isValidUser() && resource.data.userId == uid());
    }

    // ========================================
    // Work Orders Collection
    // ========================================
    match /work_orders/{orderId} {
      allow read: if isValidUser();
      allow create: if isValidUser() && (isAdmin() || isResident());
      allow update: if isAdmin() ||
        (isValidUser() && (isWorker() || resource.data.residentId == uid()));
      allow delete: if isAdmin();
    }

    // ========================================
    // Edit Requests Collection
    // ========================================
    match /edit_requests/{reqId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == uid());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================
    // Chat Rooms Collection
    // ========================================
    match /chat_rooms/{roomId} {
      allow read: if isAdmin() || (isValidUser() && resource.data.members.hasAny([uid()]));
      allow create: if isValidUser();
      allow update: if isAdmin() || (isValidUser() && resource.data.members.hasAny([uid()]));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || (isValidUser() &&
          get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members.hasAny([uid()]));
        allow create: if isValidUser() &&
          get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.members.hasAny([uid()]);
        allow update, delete: if isAdmin();
      }
    }

    // ========================================
    // Security Logs Collection
    // ========================================
    match /security_logs/{logId} {
      allow read: if isValidUser() && (isAdmin() || isGuard());
      allow create: if isValidUser() && (isAdmin() || isGuard());
      allow update, delete: if isAdmin();
    }

    // ========================================
    // Audit Logs Collection
    // ========================================
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
